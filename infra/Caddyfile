# Caddy edge: auto-HTTPS (Let's Encrypt) for the public host, serves the SPA,
# proxies /api -> backend and the LiveKit signaling (/rtc) -> the local SFU.
# Swap the hostname here when a real domain (e.g. meet.coralclub.online) is pointed
# at this box. Everything runs on host networking, so upstreams are on localhost.
meet-coralclub.com, 178-105-146-99.sslip.io {
	encode zstd gzip

	# LiveKit signaling: WebSocket (/rtc) + validation (/rtc/validate) -> local SFU
	@livekit path /rtc /rtc/*
	handle @livekit {
		reverse_proxy localhost:7880
	}

	# Token + admin API, health, and finished recordings (served by the backend)
	handle /api/* {
		reverse_proxy localhost:8080
	}
	handle /healthz {
		reverse_proxy localhost:8080
	}
	handle /recordings/* {
		reverse_proxy localhost:8080
	}

	# Static SPA frontend
	handle {
		root * /srv
		# Hashed build assets are immutable and cache forever.
		header /assets/* Cache-Control "public, max-age=31536000, immutable"
		header /manifest.webmanifest Content-Type "application/manifest+json"
		# Everything else is the SPA shell (index.html served for "/" and every
		# client route via try_files). It must never be cached, or browsers keep
		# loading a stale index.html that points at old asset hashes. The header
		# directive matches the *request* path, so match all non-asset paths here
		# rather than "/index.html" (which "/" never hits).
		@spa not path /assets/*
		header @spa Cache-Control "no-store"
		try_files {path} /index.html
		file_server
	}
}
