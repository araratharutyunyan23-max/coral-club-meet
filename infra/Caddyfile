# Caddy edge: auto-HTTPS (Let's Encrypt) for the public host, serves the SPA,
# proxies /api -> backend and the LiveKit signaling (/rtc) -> the local SFU.
# Swap the hostname here when a real domain (e.g. meet.coralclub.online) is pointed
# at this box. Everything runs on host networking, so upstreams are on localhost.
meet-coralclub.com {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	encode zstd gzip

	# LiveKit signaling: WebSocket (/rtc) + validation (/rtc/validate) -> local SFU
	@livekit path /rtc /rtc/*
	handle @livekit {
		reverse_proxy localhost:7880
	}

	# Token + admin API, health, and finished recordings (served by the backend)
	handle /api/* {
		reverse_proxy localhost:8080
	}
	handle /healthz {
		reverse_proxy localhost:8080
	}
	handle /recordings/* {
		reverse_proxy localhost:8080
	}

	# Static SPA frontend
	handle {
		root * /srv

		# Hashed build assets are content-addressed → cache forever.
		@assets path /assets/*
		handle @assets {
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		# Self-hosted MediaPipe segmenter assets (WASM + .tflite model), served
		# same-origin so the camera background works where cdn.jsdelivr.net /
		# storage.googleapis.com are blocked. Not fingerprinted (fixed names), so
		# cache for a month rather than "immutable"; served as static files, never
		# rewritten to the SPA index. Caddy sets application/wasm for .wasm itself.
		@mediapipe path /mediapipe/*
		handle @mediapipe {
			header Cache-Control "public, max-age=2592000"
			file_server
		}

		# Offline speech-to-text model (~45 MB, fixed name) — cache long so it isn't
		# re-downloaded every time captions are turned on. Served same-origin.
		@vosk path /vosk/*
		handle @vosk {
			header Cache-Control "public, max-age=2592000"
			file_server
		}

		# Everything else is the SPA shell: index.html is served for "/" and every
		# client route via try_files. It must never be cached, or browsers keep
		# loading a stale index.html that points at old asset hashes. An
		# unconditional header here reliably covers the try_files fallback — a
		# `not path /assets/*` matcher does NOT fire for "/" once try_files rewrites.
		handle {
			header Cache-Control "no-store"
			header /manifest.webmanifest Content-Type "application/manifest+json"
			try_files {path} /index.html
			file_server
		}
	}
}
