# Backend configuration. Local-development values shown.

PORT=8080

# WebSocket URL the browser uses to reach the LiveKit SFU.
LIVEKIT_URL=ws://localhost:7880

# Local dev: when LIVEKIT_DEV=true the backend falls back to LiveKit's
# well-known dev credentials (devkey/secret, matching `livekit-server --dev`)
# if the key/secret below are empty. Leave LIVEKIT_DEV unset in production.
LIVEKIT_DEV=true

# Required in production (there is NO implicit default unless LIVEKIT_DEV=true).
# Must match the LiveKit server. Never commit real values.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Comma-separated list of browser origins allowed to call the API (CORS).
ALLOWED_ORIGINS=http://localhost:5173

# Create-meeting access code. When CREATE_CODE is set, creating a meeting
# requires this shared code (staff know it) and host role is derived server-side;
# guests still join by link freely. REQUIRED in production (the backend refuses to
# boot without it unless LIVEKIT_DEV=true) so it can never accidentally run open.
# Use a long, high-entropy value — it is the only secret gating room creation.
# NEVER commit the real value.
CREATE_CODE=

# Required whenever CREATE_CODE is set: HMAC key that signs the session cookie.
# Generate with `openssl rand -base64 48`. NEVER commit the real value.
SESSION_SECRET=
